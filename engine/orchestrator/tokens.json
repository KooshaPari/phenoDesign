{
  "version": "1.0.0",
  "name": "Keycap Palette",
  "description": "phenoDesign brand tokens (colors, typography, spacing)",
  "colors": {
    "primary": {
      "hex": "#7ebab5",
      "rgb": [126, 186, 181],
      "rgbNorm": [0.494, 0.729, 0.710],
      "hsv": [172, 32, 73],
      "name": "teal",
      "usage": "app identifiers, emission channels, headings, CTAs"
    },
    "secondary": {
      "hex": "#090a0c",
      "rgb": [9, 10, 12],
      "rgbNorm": [0.035, 0.039, 0.047],
      "hsv": [210, 25, 5],
      "name": "midnight",
      "usage": "world background, base geometry, text outlines"
    },
    "accent": {
      "hex": "#e8f4f2",
      "rgb": [232, 244, 242],
      "rgbNorm": [0.910, 0.957, 0.949],
      "name": "frost",
      "usage": "highlights, glass rim, highlights in 3D renders"
    }
  },
  "typography": {
    "primary": {
      "fontFamily": "Arial Bold",
      "fallback": "Helvetica Neue, sans-serif",
      "sizes": {
        "hero": 72,
        "heading": 48,
        "body": 24,
        "caption": 14
      },
      "weight": 700,
      "usage": "headings, app names, titles"
    },
    "secondary": {
      "fontFamily": "Courier New",
      "fallback": "Monospace",
      "sizes": {
        "code": 12,
        "label": 11
      },
      "weight": 400,
      "usage": "metadata, timestamps, code"
    }
  },
  "spacing": {
    "unit": 8,
    "scales": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32
    }
  },
  "blender": {
    "materials": {
      "teal_emission": {
        "baseColor": [0.126, 0.186, 0.181],
        "emissionColor": [0.18, 0.62, 0.56],
        "emissionStrength": 1.8,
        "roughness": 0.2,
        "metallic": 0.0
      },
      "glass": {
        "baseColor": [0.03, 0.05, 0.06],
        "roughness": 0.05,
        "metallic": 0.0,
        "transmission": 0.7,
        "ior": 1.45
      },
      "midnight": {
        "baseColor": [0.02, 0.024, 0.03],
        "emissionColor": [0.02, 0.024, 0.03],
        "emissionStrength": 0.0,
        "roughness": 0.8,
        "metallic": 0.0
      }
    },
    "world": {
      "backgroundColor": [0.02, 0.024, 0.03],
      "backgroundIntensity": 0.1,
      "volumetricDensity": 0.04
    }
  },
  "imagemagick": {
    "textColor": "#7ebab5",
    "outlineColor": "#090a0c",
    "font": "Arial-Bold",
    "fontSizes": {
      "hero": 72,
      "subtitle": 48,
      "caption": 24
    }
  },
  "ffmpeg": {
    "profiles": {
      "web": {
        "codec": "libx264",
        "preset": "fast",
        "crf": 23,
        "audioCodec": "aac",
        "audioBitrate": "128k"
      },
      "archive": {
        "codec": "libx265",
        "preset": "slow",
        "crf": 16,
        "audioCodec": "aac",
        "audioBitrate": "192k"
      },
      "fast_preview": {
        "codec": "libx264",
        "preset": "ultrafast",
        "crf": 28,
        "audioCodec": "aac",
        "audioBitrate": "96k"
      }
    }
  }
}

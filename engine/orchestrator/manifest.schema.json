{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "phenoDesign Asset Manifest",
  "description": "Manifest schema for asset rendering requests in phenoDesign engine",
  "type": "object",
  "required": ["assets", "tokens"],
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0.0",
      "description": "Manifest schema version"
    },
    "assets": {
      "type": "array",
      "description": "Array of asset specifications to render",
      "items": {
        "type": "object",
        "required": ["id", "type", "leg"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$",
            "description": "Unique asset identifier (slug)"
          },
          "type": {
            "type": "string",
            "enum": ["icon", "hero", "favicon", "gif", "video", "cinematic", "design"],
            "description": "Asset type determines processing pipeline"
          },
          "leg": {
            "type": "string",
            "enum": ["blender", "imagemagick", "ffmpeg", "unreal", "adobe"],
            "description": "Primary rendering tool/leg"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable name (used in text overlays)"
          },
          "input": {
            "type": "object",
            "description": "Input specifications",
            "properties": {
              "format": {
                "type": "string",
                "enum": ["png", "mov", "mp4", "sequence", "psd", "aep"],
                "description": "Input file format"
              },
              "path": {
                "type": "string",
                "description": "Path to input file or sequence template (e.g., frame_%04d.png)"
              },
              "resolution": {
                "type": "string",
                "pattern": "^[0-9]+x[0-9]+$",
                "description": "Input resolution (WxH), if applicable"
              }
            }
          },
          "output": {
            "type": "object",
            "description": "Output specifications",
            "properties": {
              "format": {
                "type": "string",
                "enum": ["png", "mp4", "gif", "ico", "webp", "mov", "jpg"],
                "description": "Output file format"
              },
              "path": {
                "type": "string",
                "description": "Output file path (relative to render root)"
              },
              "resolution": {
                "type": "string",
                "pattern": "^[0-9]+x[0-9]+$",
                "description": "Output resolution (WxH)"
              }
            },
            "required": ["format", "path"]
          },
          "params": {
            "type": "object",
            "description": "Tool-specific rendering parameters",
            "properties": {
              "quality": {
                "type": "string",
                "enum": ["draft", "standard", "high"],
                "default": "standard"
              },
              "text": {
                "type": "string",
                "description": "Text overlay (hero images, titles)"
              },
              "textPosition": {
                "type": "string",
                "enum": ["NorthEast", "NorthWest", "SouthEast", "SouthWest", "Center"],
                "default": "NorthEast"
              },
              "blenderParams": {
                "type": "object",
                "description": "Blender-specific: emissive intensity, glass roughness, etc.",
                "properties": {
                  "emissionStrength": { "type": "number", "default": 1.8 },
                  "glassRoughness": { "type": "number", "default": 0.05 },
                  "glassTransmission": { "type": "number", "default": 0.7 }
                }
              },
              "ffmpegParams": {
                "type": "object",
                "description": "FFmpeg-specific: fps, crf, preset, etc.",
                "properties": {
                  "fps": { "type": "number", "default": 30 },
                  "crf": { "type": "number", "default": 18, "minimum": 0, "maximum": 51 },
                  "preset": { "type": "string", "enum": ["fast", "medium", "slow"] }
                }
              }
            }
          },
          "critique": {
            "type": "object",
            "description": "Vision-critique loop settings (Claude feedback iteration)",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "maxIterations": { "type": "integer", "default": 3, "minimum": 1 },
              "scoreThreshold": { "type": "number", "default": 0.9, "minimum": 0, "maximum": 1 },
              "scoringRubric": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "criterion": { "type": "string", "description": "e.g., 'teal_saturation', 'glass_clarity'" },
                    "weight": { "type": "number" }
                  }
                }
              }
            }
          },
          "metadata": {
            "type": "object",
            "description": "Optional metadata (tags, collections, dependencies)",
            "properties": {
              "collection": { "type": "string", "description": "e.g., 'tracera-branding', 'civis-ui'" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Asset IDs that must be rendered first"
              }
            }
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "description": "Brand design tokens (colors, typography, spacing)",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "Primary brand color (teal: #7ebab5)"
            },
            "secondary": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "Secondary brand color (midnight: #090a0c)"
            },
            "accent": { "type": "string" }
          }
        },
        "typography": {
          "type": "object",
          "properties": {
            "primaryFont": { "type": "string", "default": "Arial Bold" },
            "fallbackFont": { "type": "string", "default": "Helvetica" }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "keycap": {
    "color": {
      "accent": {
        "$value": "#7ebab5",
        "$type": "color",
        "$description": "Primary teal accent"
      },
      "accent-hover": {
        "$value": "#95ccc8",
        "$type": "color",
        "$description": "Accent hover state (lighter)"
      },
      "accent-active": {
        "$value": "#6aa8a3",
        "$type": "color",
        "$description": "Accent active/pressed state"
      },
      "accent-dim": {
        "$value": "#569691",
        "$type": "color",
        "$description": "Accent muted variant"
      },
      "accent-contrast": {
        "$value": "#4a9c97",
        "$type": "color",
        "$description": "Accent for light backgrounds (WCAG AA)"
      },
      "slate": {
        "$value": "#353a40",
        "$type": "color",
        "$description": "Secondary surface / alt button background"
      }
    },
    "dark": {
      "bg": { "$value": "#090a0c", "$type": "color", "$description": "Deep midnight background" },
      "bg-alt": { "$value": "#0e1014", "$type": "color" },
      "bg-soft": { "$value": "#14171b", "$type": "color" },
      "bg-elv": { "$value": "#1a1e24", "$type": "color", "$description": "Elevated surface" },
      "text-1": { "$value": "#f6f5f5", "$type": "color", "$description": "Primary text (warm white)" },
      "text-2": { "$value": "#a8adb5", "$type": "color", "$description": "Secondary text" },
      "text-3": { "$value": "#6b7280", "$type": "color", "$description": "Muted text" },
      "divider": { "$value": "#1f2329", "$type": "color" },
      "gutter": { "$value": "#0c0d0f", "$type": "color" },
      "code-block-bg": { "$value": "#060708", "$type": "color" }
    },
    "light": {
      "bg": { "$value": "#f8f9fa", "$type": "color", "$description": "Warm paper background" },
      "bg-alt": { "$value": "#f0f1f3", "$type": "color" },
      "bg-soft": { "$value": "#e8eaed", "$type": "color" },
      "bg-elv": { "$value": "#ffffff", "$type": "color" },
      "text-1": { "$value": "#1a1c1e", "$type": "color", "$description": "Primary text (dark ink)" },
      "text-2": { "$value": "#4a4f57", "$type": "color" },
      "text-3": { "$value": "#6b7280", "$type": "color" },
      "divider": { "$value": "#d4d7dc", "$type": "color" },
      "gutter": { "$value": "#e8eaed", "$type": "color" },
      "code-block-bg": { "$value": "#f0f1f3", "$type": "color" }
    },
    "font": {
      "family-base": {
        "$value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "$type": "fontFamily"
      },
      "family-mono": {
        "$value": "'JetBrains Mono', ui-monospace, 'Cascadia Code', monospace",
        "$type": "fontFamily"
      }
    }
  }
}
